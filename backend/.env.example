DATABASE_URL=postgresql+psycopg://invest:invest@localhost:5433/invest_a_bot
REDIS_URL=redis://localhost:6379/0
HOUSE_CLERK_BASE_URL=https://disclosures-clerk.house.gov/public_disc/financial-pdfs
HOUSE_CLERK_POLL_INTERVAL_SECONDS=300
PDF_STORAGE_DIR=./data/filings

NOTIFICATIONS_ENABLED=true
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=
NOTIFICATION_TO_EMAILS=["you@example.com"]
SLACK_WEBHOOK_URL=

DAILY_DIGEST_ENABLED=true
DIGEST_TIMEZONE=America/New_York
DIGEST_TOP_N=10

# Off by default -- see config.py comment on Senate eFD's non-commercial use terms.
SENATE_INGESTION_ENABLED=false

ENRICHMENT_ENABLED=true
ENRICHMENT_MIN_RELEVANCE_SCORE=60.0
ENRICHMENT_MAX_ITEMS_PER_ALERT=10
SEC_USER_AGENT=invest-a-bot contact:you@example.com

CELERY_TIMEZONE=America/New_York
ALERT_PIPELINE_INTERVAL_SECONDS=120
ENRICHMENT_PIPELINE_INTERVAL_SECONDS=900
DAILY_DIGEST_HOUR=8
DAILY_DIGEST_MINUTE=0
